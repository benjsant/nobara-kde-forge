{
  "tlp": {
    "packages": ["tlp", "tlp-rdw"],
    "remove_conflicts": ["power-profiles-daemon"],
    "config": {
      "CPU_SCALING_GOVERNOR_ON_AC": "performance",
      "CPU_SCALING_GOVERNOR_ON_BAT": "powersave",
      "CPU_ENERGY_PERF_POLICY_ON_AC": "balance_performance",
      "CPU_ENERGY_PERF_POLICY_ON_BAT": "power",
      "WIFI_PWR_ON_AC": "off",
      "WIFI_PWR_ON_BAT": "on",
      "RUNTIME_PM_ON_AC": "on",
      "RUNTIME_PM_ON_BAT": "auto",
      "USB_AUTOSUSPEND": 1,
      "PCIE_ASPM_ON_AC": "default",
      "PCIE_ASPM_ON_BAT": "powersupersave"
    }
  },
  "monitoring": {
    "packages": [
      { "name": "lm_sensors", "description": "Capteurs temperature CPU/GPU" },
      { "name": "smartmontools", "description": "Sante SSD/HDD (SMART)" },
      { "name": "acpi", "description": "Infos batterie et alimentation" },
      { "name": "powertop", "description": "Analyse consommation energetique" },
      { "name": "inxi", "description": "Informations systeme detaillees" },
      { "name": "mesa-demos", "description": "Infos GPU (glxinfo)" },
      { "name": "nvme-cli", "description": "Gestion et sante SSD NVMe" }
    ]
  },
  "dock": {
    "logind_settings": {
      "HandleLidSwitch": "suspend",
      "HandleLidSwitchExternalPower": "ignore",
      "HandleLidSwitchDocked": "ignore"
    }
  },
  "vendor_specific": {
    "asus": {
      "packages": [
        { "name": "asusctl", "description": "Controle ventilateurs, profils perf, LEDs (ASUS ROG/TUF)" },
        { "name": "supergfxctl", "description": "Commutation GPU hybride (ASUS optimus)" },
        { "name": "rog-control-center", "description": "Interface GUI asusctl (KDE)" }
      ]
    }
  },
  "thermal": {
    "services": [
      { "name": "bluetooth.service", "description": "Bluetooth" },
      { "name": "cups.service", "description": "Impression (CUPS)" },
      { "name": "avahi-daemon.service", "description": "Decouverte reseau (Avahi)" },
      { "name": "ModemManager.service", "description": "Gestion modem" }
    ]
  },
  "checks": [
    { "name": "CPU", "cmd": "lscpu | head -15", "live_usb": true },
    { "name": "RAM", "cmd": "free -h | head -2", "live_usb": true },
    { "name": "Stockage", "cmd": "lsblk -d -o NAME,SIZE,TYPE,ROTA,TRAN | grep -v loop", "live_usb": true },
    { "name": "GPU", "cmd": "lspci | grep -i 'vga\\|3d\\|display'", "live_usb": true },
    { "name": "Ecrans", "cmd": "xrandr --query 2>/dev/null | grep ' connected' || echo '(xrandr indisponible)'", "live_usb": false },
    { "name": "WiFi", "cmd": "nmcli -t -f DEVICE,TYPE,STATE device | grep wifi || echo 'Pas de WiFi'", "live_usb": true },
    { "name": "Batterie", "cmd": "acpi -V 2>/dev/null | head -5 || cat /sys/class/power_supply/BAT*/capacity 2>/dev/null || echo 'Pas de batterie'", "live_usb": false },
    { "name": "Temperature", "cmd": "sensors 2>/dev/null | head -20 || echo 'lm-sensors non installe'", "live_usb": false }
  ]
}
