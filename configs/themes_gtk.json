      "description": "Default KDE Breeze GTK theme"
    },
    {
      "name": "Orchis-theme",
      "name_to_use": "Orchis-Dark",
      "url": "https://github.com/vinceliuice/Orchis-theme.git",
      "cmd_user": "./install.sh -t default -c dark -l --tweaks compact",
      "cmd_root": "sudo ./install.sh -t default -c dark -l --tweaks compact -d /usr/share/themes",
      "description": "Modern GTK theme"
    },
    {
      "name": "Sweet",
      "name_to_use": "Sweet-Dark",
      "url": "https://github.com/EliverLara/Sweet.git",
      "cmd_user": "mkdir -p ~/.themes && cp -r Sweet-Dark ~/.themes/",
      "cmd_root": "sudo cp -r Sweet-Dark /usr/share/themes/",
      "description": "Theme GTK violet/sombre moderne (esthetique Nobara)"
    },
    {
      "name": "Layan-gtk-theme",
      "name_to_use": "Layan-Dark",
      "url": "https://github.com/vinceliuice/Layan-gtk-theme.git",
      "cmd_user": "./install.sh -c dark",
      "cmd_root": "sudo ./install.sh -c dark -d /usr/share/themes",
      "description": "Theme GTK Material Design (vinceliuice)"
    },
    {
      "name": "Catppuccin-GTK",
      "name_to_use": "Catppuccin-Mocha-Standard-Lavender-Dark",
      "url": "https://github.com/Fausto-Korpsvart/Catppuccin-GTK-Theme.git",
      "cmd_user": "cd themes && ./install.sh -t lavender -c dark -s standard",
      "cmd_root": "cd themes && sudo ./install.sh -t lavender -c dark -s standard -d /usr/share/themes",
      "description": "Catppuccin Mocha Lavender (pendant GTK du Kvantum)"
    }
  ]
